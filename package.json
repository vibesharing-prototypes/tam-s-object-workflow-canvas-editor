{
  "name": "build-day-workflow-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@hono/node-server": "^1.13.7",
    "@mui/material": "^7.0.0",
    "@tanstack/react-query": "^5.59.0",
    "better-sqlite3": "^11.5.0",
    "reactflow": "^11.11.4",
    "dagre": "^0.8.5",
    "hono": "^4.6.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
